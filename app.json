{
  "expo": {
    "name": "WalkieTalkie Offline",
    "slug": "offwalk",
    "version": "1.0.0",
    "owner": "manik5131149s-team",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.manik.walkietalkie",
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_ADVERTISE",
        "NEARBY_WIFI_DEVICES",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_CONNECTED_DEVICE"
      ]
    },
    "plugins": [
      "expo-task-manager",
      [
        "expo-notifications",
        {
          "color": "#00F0FF"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b30cb65b-c065-4ecb-bbe8-bc7bcb8ea6f8"
      }
    }
  }
}
